import * as utils from "./utils.jsx";
import { Badge, Column, GroupSections, Table } from "./utils.jsx";

export default function ({ data = [], meta = {}, t }) {
  const { report = {} } = meta;

  const columns = [
    /* __COLUMNS__ */
  ];

  data = utils.sort(data, report.properties?.sort || []);

  data = utils.group(data, report.properties?.groups || [], columns);

  const visibleColumns = settings?.columns ?? [];

  return (
    <div className="report-wrapper">
      <div className={`report-container ${settings?.pageSize ?? "a4"} ${settings?.orientation}`}>
        <header>
          <h1>{t("__TITLE_KEY__")}</h1>
          <section className="parameters">
            {/* __PARAMETERS__ */}
          </section>
        </header>
        <main>
          <GroupSections
            columns={columns}
            data={data}
            groups={report.properties?.groups || []}>
            {(groupData) => (
              <div className="content">
                <Table data={groupData}
                  visibleColumns={visibleColumns}>
                  {columns.map((column, index) => (
                    <Column key={index} {...column} />
                  ))}
                </Table>
              </div>
            )}
          </GroupSections>
        </main>
      </div>
    </div>
  );
}
