{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EmployeeList",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "integer",
        "description": "The unique identifier for an employee."
      },
      "name": {
        "type": "string",
        "description": "The full name of the employee."
      },
      "age": {
        "type": "integer",
        "minimum": 0,
        "description": "The age of the employee."
      },
      "department": {
        "type": "string",
        "description": "The department the employee belongs to."
      }
    },
    "required": [
      "id",
      "name",
      "age"
    ]
  }
}