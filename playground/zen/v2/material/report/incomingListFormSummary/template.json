{
  "engine": "react",
  "meta": {
    "dataSource": "/material/data/incomingListCube",
    "delegate": "/v2/material/report/incomingListForm",
    "report": {
      "properties": {
        "#settings": {
          "columns": [
            "productPacking_code",
            "productPacking_complement",
            "productVariant_description",
            "sum_quantity",
            "sum_grossWeightKg",
            "count"
          ],
          "dataSource": {
            "parameters": {
              "SHOW_ENTITY": true,
              "SHOW_ITEM": false,
              "SHOW_PRODUCT": true,
              "SHOW_UNIT": true,
              "SHOW_PRODUCT_PACKING": true,
              "SHOW_PRODUCT_VARIANT": true,
              "SHOW_ADDRESS": false,
              "SHOW_QUALITY": false,
              "SHOW_LOT": false,
              "SHOW_SERIAL": false,
              "SHOW_EXPIRATION_DATE": false,
              "SHOW_HANDLING_UNIT": false
            }
          },
          "groups": [
            {
              "columnId": "product_calc"
            }
          ],
          "sort": [
            {
              "columnId": "product_code"
            },
            {
              "columnId": "productPacking_code"
            }
          ]
        }
      }
    }
  }
}